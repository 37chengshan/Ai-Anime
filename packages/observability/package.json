{
  "name": "@ai-anime/observability",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "test -d src && ls src/*.ts 2>/dev/null | head -1 | xargs -r tsup --format cjs,esm --dts || echo \"No src files to build\"",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@sentry/node": "^7.0.0"
  }
}
